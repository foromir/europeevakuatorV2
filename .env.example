# Публичный origin сайта (SEO, sitemap)
VITE_SITE_ORIGIN=https://abschleppdienst24.org

# Токен для unpack.php при FTP-деплое (npm run pack). Необязательно — если пусто, генерируется автоматически.
DEPLOY_TOKEN=

# Google Maps embed — Google Business → Поделиться → Встроить карту → скопировать src из iframe
# Пример: https://www.google.com/maps/embed?pb=...
VITE_GOOGLE_MAPS_EMBED_SRC=

# Ссылка на карточку компании (кнопка «Все отзывы в Google»)
VITE_GOOGLE_MAPS_PLACE_URL=

# Elfsight Google Reviews — ID виджета (elfsight-app-…). По умолчанию уже задан в коде.
VITE_ELFSIGHT_REVIEWS_APP_ID=
